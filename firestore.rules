rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of a document (by UID)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper function to check if the user has access to a trip
    function canAccessTrip(tripData) {
      return isSignedIn() && (
        tripData.userId == request.auth.uid || 
        (tripData.collaborators != null && request.auth.token.email in tripData.collaborators)
      );
    }

    // Helper function to fetch a trip's data and check access
    function canAccessTripById(tripId) {
      let trip = get(/databases/$(database)/documents/trips/$(tripId)).data;
      return canAccessTrip(trip);
    }

    // User Settings: Only the user themselves can access their settings
    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Trips: Owners and collaborators can read/write
    match /trips/{tripId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if canAccessTrip(resource.data);
    }

    // Related collections: Tied to a trip
    match /destinations/{id} {
      allow read, write: if isSignedIn() && (
        (request.method == 'create' && canAccessTripById(request.resource.data.tripId)) ||
        (request.method != 'create' && canAccessTripById(resource.data.tripId))
      );
    }
    
    match /activities/{id} {
      allow read, write: if isSignedIn() && (
        (request.method == 'create' && canAccessTripById(request.resource.data.tripId)) ||
        (request.method != 'create' && canAccessTripById(resource.data.tripId))
      );
    }
    
    match /expenses/{id} {
      allow read, write: if isSignedIn() && (
        (request.method == 'create' && canAccessTripById(request.resource.data.tripId)) ||
        (request.method != 'create' && canAccessTripById(resource.data.tripId))
      );
    }
    
    match /documents/{id} {
      allow read, write: if isSignedIn() && (
        (request.method == 'create' && canAccessTripById(request.resource.data.tripId)) ||
        (request.method != 'create' && canAccessTripById(resource.data.tripId))
      );
    }
  }
}